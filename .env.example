# --- Frontend (Next.js) — copiar a .env en la raíz del repo ---

# API Django (sin barra final). Vercel: misma variable en Build y Runtime (Next usa la URL al build para images.remotePatterns).
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL canónica del sitio (SEO, Open Graph, sitemap.xml / robots.txt). En producción: https://tudominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Perfiles públicos (Hero + footer). Sustituí por tus URLs reales.
NEXT_PUBLIC_GITHUB_URL=https://github.com/tu-usuario
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/tu-perfil

# Revalidación ISR: mismo secreto que REVALIDATION_SECRET en backend/.env
# REVALIDATION_SECRET=un-token-secreto-compartido

# --- Sentry (opcional; tras `npx @sentry/wizard -i nextjs`) ---
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Backend (Django): ver backend/.env.example
