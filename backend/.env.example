# Django
DEBUG=False
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# DB (Railway Postgres usually provides DATABASE_URL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Frontend URL for admin "View site" + revalidate callback
FRONTEND_URL=https://shulo.dev
REVALIDATION_SECRET=change-me

# CORS/CSRF allowlist (comma-separated)
CORS_ALLOWED_ORIGINS=https://shulo.dev,https://www.shulo.dev
CSRF_TRUSTED_ORIGINS=https://shulo.dev,https://www.shulo.dev
